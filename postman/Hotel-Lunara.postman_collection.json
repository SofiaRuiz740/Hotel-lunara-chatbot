            "url": "{{baseUrl}}/api/rooms"
          }
        },
        {
          "name": "Room Availability",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const checkIn = new Date();",
                  "checkIn.setDate(checkIn.getDate() + 7);",
                  "const checkOut = new Date(checkIn);",
                  "checkOut.setDate(checkOut.getDate() + 2);",
                  "const formatDate = (value) => value.toISOString().slice(0, 10);",
                  "pm.environment.set('publicCheckInDate', formatDate(checkIn));",
                  "pm.environment.set('publicCheckOutDate', formatDate(checkOut));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/rooms/availability?checkIn={{publicCheckInDate}}&checkOut={{publicCheckOutDate}}&adults=2&children=0&type=DOBLE"
          }
        },
        {
          "name": "List Services",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
